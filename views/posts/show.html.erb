<% content_for(:title, @post.name) %>

<% content_for :content do %>
    <h1><% @post.name %><h1>
    <p><%= @post.content %></p>
    <p>
        <a href="<%= posts_path %>" class="btn btn-primary">Revenir aux articles</a>
    </p>
<% end %>

<% content_for :sidebar do %>
    Exemple de contenu de la sidebar.
<% end %>

<%= render template: 'layouts/sidebar' %>